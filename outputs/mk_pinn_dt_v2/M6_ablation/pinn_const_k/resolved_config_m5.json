      "mu_ref_mPa_s": {
        "value": 0.035,
        "range": [
          0.02,
          0.06
        ],
        "meaning": "Lee-Gonzalez-Eakin关联式估算(γg=0.577,ρ=0.271g/cm³,T=140.32°C,p=75.7MPa)→0.0346≈0.035"
      },
      "cg_ref_1_per_MPa": {
        "value": 0.013,
        "range": [
          0.008,
          0.02
        ],
        "meaning": "参考压缩系数先验（可被M3 PVT在p_ref,T_ref查询覆盖）"
      },
      "c_r_1_per_MPa": {
        "value": 0.0,
        "meaning": "岩石压缩系数（目前无数据, 置0）"
      },
      "frac_conductivity_factor": {
        "value": 16.0,
        "trainable": true,
        "bounds": [
          1.0,
          100.0
        ],
        "meaning": "裂缝增效因子(v3.12: k_frac=k_eff×f=0.5×16=8mD; PVT修正后Bg≈2×旧值, k_frac需相应提高; 附表8 SY9局部裂缝层k=36.8mD由k_net捕捉)"
      }
    },
    "pde": {
